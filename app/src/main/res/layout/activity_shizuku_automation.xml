<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/botdrop_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <ImageButton
                android:id="@+id/btn_back_to_dashboard"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_back_chevron"
                android:contentDescription="@string/botdrop_back"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:tint="@color/botdrop_accent"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:padding="0dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="16dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_service_notification"
                    android:contentDescription="@string/botdrop_automation_panel_title"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/botdrop_automation_panel_title"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/botdrop_on_background" />
            </LinearLayout>
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/botdrop_card_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/botdrop_shizuku_panel_title"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/botdrop_on_background"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/automation_status_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/botdrop_shizuku_status_checking"
                android:textSize="13sp"
                android:textColor="@color/botdrop_secondary_text"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/automation_shizuku_bridge_status_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/botdrop_shizuku_bridge_status_checking"
                android:textSize="13sp"
                android:textColor="@color/botdrop_secondary_text"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_open_shizuku"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="@string/action_open_shizuku_status"
                    android:textAllCaps="false"
                    android:background="@drawable/botdrop_button_bg"
                    android:textColor="#1A1A1A" />

                <Button
                    android:id="@+id/btn_request_shizuku_permission"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="@string/action_request_shizuku_permission"
                    android:textAllCaps="false"
                    android:background="@drawable/botdrop_button_outline_bg"
                    android:textColor="@color/botdrop_accent" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/botdrop_card_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/botdrop_u2_service_panel_title"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/botdrop_on_background"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/automation_u2_status_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/botdrop_u2_service_status_checking"
                android:textSize="13sp"
                android:textColor="@color/botdrop_secondary_text"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_start_u2_service"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="@string/botdrop_start_u2_service"
                    android:textAllCaps="false"
                    android:background="@drawable/botdrop_button_bg"
                    android:textColor="#1A1A1A" />

                <Button
                    android:id="@+id/btn_stop_u2_service"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="@string/botdrop_stop_u2_service"
                    android:textAllCaps="false"
                    android:background="@drawable/botdrop_button_outline_bg"
                    android:textColor="@color/botdrop_accent" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
