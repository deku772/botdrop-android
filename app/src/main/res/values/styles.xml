<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:android="http://schemas.android.com/apk/res/android">

    <style name="TermuxAlertDialogStyle" parent="@android:style/Theme.Material.Dialog.Alert">
        <!-- BotDrop dark theme for dialogs -->
        <item name="android:colorAccent">@color/botdrop_accent</item>
        <item name="android:textColorPrimary">@color/botdrop_on_background</item>
        <item name="android:textColorSecondary">@color/botdrop_secondary_text</item>
        <item name="android:background">@drawable/botdrop_dialog_card_bg</item>
        <item name="android:windowBackground">@drawable/botdrop_dialog_card_bg</item>
    </style>

    <style name="TermuxActivity.Drawer.ButtonBarStyle.Light" parent="@style/Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/botdrop_on_background</item>
    </style>

    <style name="TermuxActivity.Drawer.ButtonBarStyle.Dark" parent="@style/Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/botdrop_on_background</item>
        <item name="rippleColor">@color/botdrop_accent</item>
    </style>

    <style name="BotDropChannelTabText">
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
        <item name="android:textAlignment">center</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="BotDropChannelOpenSetupLink">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/botdrop_accent</item>
        <item name="android:paddingTop">2dp</item>
        <item name="android:paddingBottom">2dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="BotDropChannelActionButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textSize">14sp</item>
        <item name="android:padding">12dp</item>
        <item name="android:textStyle">bold</item>
    </style>

</resources>
